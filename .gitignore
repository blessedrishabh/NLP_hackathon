# ==============================================================================
# ROBUST BASE .GITIGNORE
# Covers: OS junk, IDE settings, Security, and Common Logs
# ==============================================================================

# --- Operating System Files ---
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.fuse_hidden*
.directory
.Trash-*

# --- IDE & Editor Settings ---
# VS Code (Keep settings.json if you want team-shared settings, otherwise ignore .vscode/)
.vscode/
*.code-workspace

# JetBrains (IntelliJ, PyCharm, WebStorm, etc.)
.idea/
*.iws
*.iml
*.ipr

# Eclipse
.metadata/
bin/
tmp/
*.tmp
*.bak
*.swp
*~.nib
local.properties
.settings/
.loadpath
.recommenders

# Sublime Text
*.sublime-workspace

# Vim
*.swp
*.swo

# --- Logs & Databases ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.sqlite
*.sqlite3

# --- Security & Environment (CRITICAL) ---
# NEVER commit secrets or local environment configs
.env
.venv
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem
*.key
*.pub
id_rsa
id_rsa.pub
venv/
ENV/

# --- General Build/Temp Folders ---
dist/
build/
temp/
tmp/
out/
coverage/

# ==============================================================================
# END OF BASE. ADD LANGUAGE-SPECIFIC RULES BELOW
# Examples: node_modules/ (Node), __pycache__/ (Python), target/ (Java/Rust)
# ==============================================================================

# --- Node.js ---
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml
.npm/

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/
*.egg
.pytest_cache/
.coverage
htmlcov/

# --- Project-Specific ---
# Exclude chroma_db and output directories during development (comment out if needed)
# chroma_db/
# output/
# parsed_sections.json
